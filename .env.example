# Application
NODE_ENV=development
HOST=localhost
PORT=3000
API_KEY=your_secure_api_key_here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ups_monitor
DB_USER=ups_admin
DB_PASSWORD=secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# SNMP
SNMP_TIMEOUT=5000
SNMP_RETRIES=1

# Polling
POLL_INTERVAL=60

# Aggregation (cron expressions)
AGGREGATION_HOURLY_CRON=0 * * * *
AGGREGATION_DAILY_CRON=5 0 * * *
AGGREGATION_WEEKLY_CRON=15 0 * * 0
AGGREGATION_MONTHLY_CRON=30 0 1 * *

# Data Retention (days)
RETENTION_RAW_DAYS=30
RETENTION_HOURLY_DAYS=365
RETENTION_DAILY_DAYS=1095
RETENTION_WEEKLY_DAYS=1825
